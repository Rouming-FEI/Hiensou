---
import MainGridLayout from "@layouts/MainGridLayout.astro";

const title = "随笔";
const description = "随性而写，记录生活中的点滴感悟";
---

<MainGridLayout title={title} description={description}>
  <div class="card-base rounded-(--radius-large) p-8">
    <div class="text-center py-16">
      <div class="text-2xl font-bold text-(--primary) mb-4">{title}</div>
      <p class="text-75">{description}</p>
    </div>
  </div>
</MainGridLayout>
