---
import MainGridLayout from "@layouts/MainGridLayout.astro";

const title = "随笔";
const description = "随性而写，记录生活中的点滴感悟";
---

<MainGridLayout title={title} description={description}>
  <div id="essays-container" class="onload-animation">
  </div>
</MainGridLayout>

<script>
  const MONTH_NAMES = ["1月", "2月", "3月", "4月", "5月", "6月", "7月", "8月", "9月", "10月", "11月", "12月"];

  let offset = 0;
  let hasMore = true;
  let loading = false;
  let currentYear: number | null = null;
  let currentMonth: number | null = null;

  const container = document.getElementById("essays-container")!;

  // 动态创建加载指示器和兜底 sentinel，确保在内容之后
  const sentinel = document.createElement("div");
  sentinel.className = "essays-sentinel h-1";

  function createSpinner(): HTMLElement {
    const div = document.createElement("div");
    div.className = "flex items-center justify-center py-8";
    div.innerHTML = '<div class="w-6 h-6 border-2 border-(--primary) border-t-transparent rounded-full animate-spin"></div>';
    return div;
  }

  function createYearHeader(year: number): HTMLElement {
    const div = document.createElement("div");
    div.className = "text-2xl font-bold text-(--primary) mt-8 mb-4 first:mt-0";
    div.textContent = `${year}年`;
    return div;
  }

  function createMonthHeader(month: number): HTMLElement {
    const div = document.createElement("div");
    div.className = "text-lg font-semibold text-90 border-b border-(--line-divider) pb-2 mb-4 mt-6";
    div.textContent = MONTH_NAMES[month];
    return div;
  }

  function createEntry(item: { id: string; title: string; description: string; published: string }): HTMLElement {
    const date = new Date(item.published);
    const day = date.getDate();
    const weekday = date.toLocaleDateString("zh-CN", { weekday: "short" });

    const card = document.createElement("div");
    card.className = "card-base rounded-(--radius-large) p-4 mb-3 hover:border-(--primary)/30 transition-colors";

    card.innerHTML = `
      <div class="flex items-start gap-4">
        <div class="shrink-0 w-12 text-center pt-0.5">
          <div class="text-lg font-bold text-(--primary) leading-tight">${day}</div>
          <div class="text-xs text-60 mt-0.5">${weekday}</div>
        </div>
        <div class="min-w-0 flex-1">
          <div class="text-90 font-medium mb-1 truncate">${item.title}</div>
          ${item.description ? `<p class="text-75 text-sm line-clamp-2">${item.description}</p>` : ""}
        </div>
      </div>
    `;

    return card;
  }

  function renderItems(items: Array<{ id: string; title: string; description: string; published: string; year: number; month: number }>) {
    // 移除旧 sentinel，追加内容后再挂回去
    sentinel.remove();
    for (const item of items) {
      if (item.year !== currentYear) {
        currentYear = item.year;
        currentMonth = null;
        container.appendChild(createYearHeader(item.year));
      }
      if (item.month !== currentMonth) {
        currentMonth = item.month;
        container.appendChild(createMonthHeader(item.month));
      }
      container.appendChild(createEntry(item));
    }
    container.appendChild(sentinel);
  }

  async function loadMore() {
    if (loading || !hasMore) return;
    loading = true;

    const spinner = createSpinner();
    container.appendChild(spinner);

    try {
      const resp = await fetch(`/api/essays.json?offset=${offset}`);
      const data = await resp.json();
      hasMore = data.hasMore;
      offset = data.nextOffset;
      renderItems(data.items);
    } catch (err) {
      console.error("加载随笔失败:", err);
    } finally {
      spinner.remove();
    }
  }

  // 初始化：先挂 sentinel 再触发首次加载
  container.appendChild(sentinel);
  const observer = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) loadMore();
    },
    { rootMargin: "200px" },
  );
  observer.observe(sentinel);
  loadMore();
</script>
