---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getSeriesList } from "@/utils/content-utils";
import { url } from "@/utils/url-utils";

const seriesList = await getSeriesList();
---

<MainGridLayout title="系列文章" description="按系列浏览文章">
  <div class="card-base px-8 py-6 mb-4">
    <div class="text-2xl font-bold text-(--primary) mb-2">系列文章</div>
    <p class="text-30 text-sm">{seriesList.length} 个系列</p>
  </div>

  {seriesList.length === 0 ? (
    <div class="card-base px-8 py-12 text-center">
      <Icon is:inline name="material-symbols:bookmark-off" class="text-5xl text-30 mx-auto mb-4" />
      <p class="text-30">暂无系列</p>
    </div>
  ) : (
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {seriesList.map((s) => (
        <a href={url(`/series/${s.id}/`)} class="card-base p-6 group hover:border-(--primary)/30 transition-colors">
          <div class="flex items-start gap-3">
            <div class="shrink-0 w-12 h-12 rounded-xl bg-(--primary)/10 flex items-center justify-center text-(--primary) text-xl">
              📖
            </div>
            <div class="min-w-0 flex-1">
              <h2 class="font-bold text-90 group-hover:text-(--primary) transition-colors truncate">
                {s.name}
              </h2>
              <p class="text-sm text-30 mt-1 line-clamp-2">{s.description}</p>
              <p class="text-xs text-(--primary) mt-2">{s.count} 篇文章</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  )}
</MainGridLayout>
